import React from "react";
import { NavLink } from "react-router-dom";
import { IoHomeSharp, IoSearch, IoHeart } from "react-icons/io5";
import { IoMdSettings } from "react-icons/io";
import "../../css/sidemenu/SideMenu.css";

const Sidebar = () => {
  return (
    <div className="sidemenu">
      {/* Logo Section */}
      <div className="logo-section">
        <div className="logo-icon">🎵</div>
        <div className="logo-text">Synthesia</div>
      </div>

      {/* Navigation Menu */}
      <nav className="nav-menu">
        <NavLink
          to="/home"
          className={({ isActive }) => `nav-item ${isActive ? "active" : ""}`}
        >
          <IoHomeSharp className="icon" />
          <span>Home</span>
        </NavLink>

        <NavLink
          to="/search"
          className={({ isActive }) => `nav-item ${isActive ? "active" : ""}`}
        >
          <IoSearch className="icon" />
          <span>Search</span>
        </NavLink>

        <NavLink
          to="/favourites"
          className={({ isActive }) => `nav-item ${isActive ? "active" : ""}`}
        >
          <IoHeart className="icon" />
          <span>My Favourite</span>
        </NavLink>
      </nav>

      {/* User Profile Section */}
      <div className="user-profile">
        <div className="user-avatar">👤</div>
        <div className="user-info">
          <div className="user-name">Rohit kumar</div>
        </div>
        <IoMdSettings className="settings-icon" />
      </div>
    </div>
  );
};

export default Sidebar;
