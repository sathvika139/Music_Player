import React from "react";
import { usePlayer } from "../../context/PlayerContext";
import { ACTIONS } from "../../context/PlayerContext";
import "./SongList.css";

const SongList = ({ songs, playlistName }) => {
  const { state, dispatch } = usePlayer();

  const formatDuration = (seconds) => {
    if (!seconds) return "0:00";
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    return `${mins}:${secs.toString().padStart(2, "0")}`;
  };

  const formatYear = (dateString) => {
    if (!dateString) return "N/A";
    return new Date(dateString).getFullYear();
  };

  const handleSongClick = (song) => {
    dispatch({
      type: ACTIONS.SET_CURRENT_SONG,
      payload: song,
    });
    dispatch({
      type: ACTIONS.SET_PLAYING,
      payload: true,
    });
  };

  if (!songs || songs.length === 0) {
    return (
      <div className="no-songs">
        <p>No songs available</p>
      </div>
    );
  }

  return (
    <div className="song-list-container">
      <div className="song-list-header">
        <div className="header-col no-col">NO</div>
        <div className="header-col name-col">NAME</div>
        <div className="header-col artist-col">ARTIST</div>
        <div className="header-col year-col">YEAR</div>
        <div className="header-col duration-col">DURATION</div>
      </div>

      <div className="song-list-body">
        {songs.map((song, index) => (
          <div
            key={song.id}
            className={`song-row ${state.currentSong?.id === song.id ? "active" : ""}`}
            onClick={() => handleSongClick(song)}
          >
            <div className="song-col no-col">{index + 1}</div>
            <div className="song-col name-col">
              <div className="song-info">
                {song.image && (
                  <img
                    src={song.image}
                    alt={song.name}
                    className="song-thumbnail"
                  />
                )}
                <span className="song-title">{song.name}</span>
              </div>
            </div>
            <div className="song-col artist-col">
              {song.artist || "Unknown"}
            </div>
            <div className="song-col year-col">
              {formatYear(song.releasedate)}
            </div>
            <div className="song-col duration-col">
              {formatDuration(song.duration)}
            </div>
          </div>
        ))}
      </div>
    </div>
  );
};

export default SongList;
